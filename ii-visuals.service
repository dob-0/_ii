[Unit]
Description=ii Visual Engine (TTY1)
After=multi-user.target
Conflicts=getty@tty1.service

[Service]
Type=simple
User=dob
WorkingDirectory=/home/dob/_ii
ExecStart=/usr/bin/python3 /home/dob/_ii/visuals.py
StandardInput=tty
StandardOutput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
